# ANTHROPIC_API_KEY=sk-ant-...
# CAMEL_PET_MODEL=claude-haiku-4-5
# CAMEL_PET_PORT=8765

# To use an OpenAI-compatible endpoint instead of Anthropic:
# CAMEL_PET_PLATFORM=openai_compatible
# CAMEL_PET_MODEL=gpt-4o-mini
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_BASE_URL=

# To use MiniMax (via Anthropic SDK):
# CAMEL_PET_PLATFORM=minmax
# CAMEL_PET_MODEL=MiniMax-M2.7
# MINIMAX_API_KEY=sk-api-...
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# Vision model for screen activity monitor (must support image inputs).
# Defaults to MiniMax M2-7. Falls back to MINIMAX_API_KEY / ANTHROPIC_API_KEY.
# CAMEL_PET_VISION_PLATFORM=minmax
# CAMEL_PET_VISION_MODEL=MiniMax-M2.7
# CAMEL_PET_VISION_API_KEY=
# CAMEL_PET_VISION_BASE_URL=

# Max pixel dimension (longest side) for resized screenshots sent to vision models.
# Lower values reduce API token cost; higher values preserve more detail.
# CAMEL_PET_SCREENSHOT_MAX_DIM=256

# Directory to save captured screenshots for local monitoring.
# Defaults to <APPDATA>/CamelPet/screenshots on Windows.
# CAMEL_PET_SCREENSHOTS_DIR=C:\Users\you\Pictures\CamelPetScreenshots
