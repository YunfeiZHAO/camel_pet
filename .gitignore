# ---------- Secrets ----------
# Never commit API keys or local env files.
.env
.env.*
!.env.example
agent/.env
agent/.env.*
!agent/.env.example

# ---------- Node / Vue / Vite ----------
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
*.egg

# Virtual envs
.venv/
venv/
env/
agent/.venv/

# Poetry
# (Commit poetry.lock; it's part of the repo contract.)

# PyInstaller
agent/dist/
agent/build/
agent/*.spec
agent/__main__.spec

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------- Rust / Tauri ----------
src-tauri/target/
src-tauri/gen/
src-tauri/Cargo.lock.bak

# Frozen Python binaries that build.py drops here
src-tauri/binaries/

# ---------- IDE / Editor ----------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Local app data (if it ever lands in-tree) ----------
memory.db
*.sqlite
*.sqlite3
*.db-journal


# ---------- Screenshots (if not saved to a user directory) ----------
data/
context_files/
local/